# Zenny Core Environment Variables
# Copy this to .env for local development ONLY.
# NEVER commit .env to Git. Set vars on Railway/Hetzner dashboards in production.

# Server
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development

# Supabase (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis / Upstash (Required)
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_USERNAME=default

# LLM Providers (Required)
GEMINI_API_KEY=your-gemini-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Voiceflow (Required)
VOICEFLOW_DMAPI_KEY=your-voiceflow-key

# n8n (Required)
N8N_WEBHOOK_URL=https://your-n8n-domain.com/webhook
N8N_SECRET=your-n8n-secret

# Integrations --- Channels (Optional, enable as needed)
SENDGRID_API_KEY=SG...
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_ACCOUNT_SID=AC...
META_APP_SECRET=your-meta-secret
META_PAGE_ACCESS_TOKEN=your-page-token

# Security (Required)
ADMIN_PASSWORD=your-secure-admin-password
JWT_SECRET=your-jwt-secret-min-32-chars

